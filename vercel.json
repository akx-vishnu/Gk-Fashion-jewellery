{
  "version": 2,
  "rewrites": [
    {
      "source": "/admin",
      "destination": "/backend/index.html"
    },
    {
      "source": "/products",
      "destination": "/api/index.js"
    },
    {
      "source": "/products/:id",
      "destination": "/api/index.js"
    },
    {
      "source": "/upload",
      "destination": "/api/index.js"
    },
    {
      "source": "/login",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/$1"
    }
  ]
}
